@model Tienda.Models.ProductoModel

@{
    ViewBag.Title = "Detalle del Producto";
}

<!-- SECTION -->
<div class="section">

    <div class="container">

        <div class="row">
            <div class="col-md-5">

                <div class="product">

                    <div class="product-img">

                        @if (!String.IsNullOrEmpty(Model.ImagenUrl))
                        {
                            <img src="@Url.Content(Model.ImagenUrl)"
                                 alt="@Model.NombreProducto"
                                 class="img-responsive"
                                 style="width:100%; height:500px; object-fit:cover;" />
                        }
                        else
                        {
                            <img src="@Url.Content("~/Content/img/product01.png")"
                                 alt="Sin imagen"
                                 class="img-responsive"
                                 style="width:100%; height:500px; object-fit:cover;" />
                        }

                    </div>

                </div>

            </div>

            <!-- ============================================= -->
            <!-- INFORMACIÓN DEL PRODUCTO -->
            <!-- ============================================= -->

            <div class="col-md-7">

                <p class="product-category">

                    @Model.Categoria

                </p>

                <h2>

                    @Model.NombreProducto

                </h2>

                <hr />

                <h3 style="color:#ff5b9a;">

                    ₡@String.Format("{0:N2}", Model.Precio)

                </h3>

                <br />

                <h4>

                    <strong>Marca:</strong>

                    @if (!String.IsNullOrEmpty(Model.Marca))
                    {
                        @Model.Marca
                    }
                    else
                    {
                        <span>No especificada</span>
                    }

                </h4>

                <h4>

                    <strong>Disponibilidad:</strong>

                    @if (Model.Stock > 0)
                    {
                        <span style="color:green;">
                            En inventario (@Model.Stock disponibles)
                        </span>
                    }
                    else
                    {
                        <span style="color:red;">
                            Agotado
                        </span>
                    }

                </h4>

                <hr />

                <h4>

                    Descripción

                </h4>

                <p style="text-align:justify;">

                    @Model.Descripcion

                </p>

                <hr />

                <h4>

                    Cantidad

                </h4>

                <input type="number"
                       id="cantidad"
                       class="form-control"
                       value="1"
                       min="1"
                       max="@Model.Stock"
                       style="width:120px;" />

                <br />

                <!-- ============================================= -->
                <!-- BOTÓN AGREGAR AL CARRITO -->
                <!-- ============================================= -->

                <div class="product-detail-actions">

                    @using (Html.BeginForm(
                        "Agregar",
                        "Carrito",
                        FormMethod.Post,
                        new { @class = "form-agregar-carrito" }))
                    {
                        @Html.Hidden("idProducto", Model.IdProducto)

                        <button type="submit" class="primary-btn">

                            <i class="fa fa-shopping-cart"></i>

                            Agregar al carrito

                        </button>
                    }

                    <a href="@Url.Action("Index", "Productos")"
                       class="primary-btn">

                        Volver al catálogo

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>
<!-- /SECTION -->
