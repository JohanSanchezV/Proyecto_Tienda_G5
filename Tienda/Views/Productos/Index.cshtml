@model List<Tienda.Models.ProductoModel>

@{
    ViewBag.Title = "Productos";
}

<!-- SECTION -->
<div class="section">
    <!-- container -->
    <div class="container">
        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success">
                @TempData["MensajeExito"]
            </div>
        }

        @if (TempData["MensajeError"] != null)
        {
            <div class="alert alert-danger">
                @TempData["MensajeError"]
            </div>
        }
        <!-- row -->
        <div class="row">
            <!-- ASIDE -->
            <div id="aside" class="col-md-3">

                @using (Html.BeginForm("Index", "Productos", FormMethod.Get))
                {

                    <!-- ========================= -->
                    <!-- FILTRO POR CATEGORÍA -->
                    <!-- ========================= -->
                    <div class="aside">

                        <h3 class="aside-title">Categories</h3>

                        <div class="checkbox-filter">

                            @foreach (var categoria in ViewBag.Categorias)
                            {
                                <div class="input-checkbox">

                                    <input type="radio"
                                           id="cat_@categoria.id_categoria"
                                           name="categoria"
                                           value="@categoria.id_categoria"
                                           @(ViewBag.CategoriaSeleccionada != null && ViewBag.CategoriaSeleccionada == categoria.id_categoria ? "checked" : "") />

                                    <label for="cat_@categoria.id_categoria">

                                        <span></span>

                                        @categoria.nombre_categoria

                                    </label>

                                </div>
                            }

                        </div>

                    </div>



                    <!-- ========================= -->
                    <!-- FILTRO POR PRECIO -->
                    <!-- ========================= -->

                    <div class="aside">

                        <h3 class="aside-title">Price</h3>

                        <div class="price-filter">

                            <div class="input-number price-min">

                                <input type="number"
                                       name="minimo"
                                       placeholder="Min"
                                       value="@ViewBag.Minimo" />

                            </div>

                            <span>-</span>

                            <div class="input-number price-max">

                                <input type="number"
                                       name="maximo"
                                       placeholder="Max"
                                       value="@ViewBag.Maximo" />

                            </div>

                        </div>

                    </div>



                    <!-- ========================= -->
                    <!-- FILTRO POR MARCA -->
                    <!-- ========================= -->

                    <div class="aside">

                        <h3 class="aside-title">Brand</h3>

                        <div class="checkbox-filter">

                            @foreach (var marca in ViewBag.Marcas)
                            {

                                <div class="input-checkbox">

                                    <input type="radio"
                                           id="marca_@marca.id_marca"
                                           name="marca"
                                           value="@marca.id_marca"
                                           @(ViewBag.MarcaSeleccionada != null && ViewBag.MarcaSeleccionada == marca.id_marca ? "checked" : "") />

                                    <label for="marca_@marca.id_marca">

                                        <span></span>

                                        @marca.nombre_marca

                                    </label>

                                </div>

                            }

                        </div>

                    </div>

                    <div class="aside">

                        <button type="submit"
                                class="primary-btn btn-block">

                            Aplicar filtros

                        </button>

                        <a href="@Url.Action("Index","Productos")"
                           class="primary-btn btn-block">

                            Limpiar filtros

                        </a>

                    </div>
                }
            </div>
            <!-- /ASIDE -->
            <!-- STORE -->
            <div id="store" class="col-md-9">

                <div class="store-filter clearfix">

                    <div class="store-sort">

                        <h4>

                            Productos encontrados:
                            <strong>@Model.Count</strong>

                        </h4>

                    </div>

                </div>



                <!-- =========================================== -->
                <!-- LISTADO DE PRODUCTOS -->
                <!-- =========================================== -->

                <div class="row">

                    @if (Model.Count > 0)
                    {

                        foreach (var producto in Model)
                        {

                            <div class="col-md-4 col-sm-6 col-xs-6">

                                <div class="product">

                                    <div class="product-img">

                                        @if (!String.IsNullOrEmpty(producto.ImagenUrl))
                                        {
                                            <img src="@Url.Content(producto.ImagenUrl)"
                                                 alt="@producto.NombreProducto"
                                                 style="height:280px; object-fit:cover;">
                                        }
                                        else
                                        {
                                            <img src="@Url.Content("~/Content/img/product01.png")"
                                                 alt="Sin imagen"
                                                 style="height:280px; object-fit:cover;">
                                        }

                                    </div>

                                    <!-- =============================== -->
                                    <!-- INFORMACIÓN DEL PRODUCTO -->
                                    <!-- =============================== -->

                                    <div class="product-body">
                                        <p class="product-category">
                                            @producto.Categoria
                                        </p>
                                        <h3 class="product-name">

                                            @producto.NombreProducto

                                        </h3>
                                        <h4 class="product-price">

                                            ₡@String.Format("{0:N2}", producto.Precio)

                                        </h4>

                                        <!-- =============================== -->
                                        <!-- BOTONES DEL PRODUCTO -->
                                        <!-- =============================== -->

                                        <div class="product-btns">
                                            <!-- BOTON DE AGREGAR A FAVORITOS -->
                                            <button class="add-to-wishlist">

                                                <i class="fa fa-heart-o"></i>

                                            </button>

                                            <!-- BOTON DE COMPARAR (NO CREO QUE SE USE) -->
                                            <button class="add-to-compare">

                                                <i class="fa fa-exchange"></i>

                                            </button>

                                            <!-- BOTON DE DETALLE PRODUCTO -->
                                            <a href="@Url.Action("Detalle", "Productos", new { id = producto.IdProducto })"
                                               class="quick-view">

                                                <i class="fa fa-eye"></i>

                                                <span class="tooltipp">
                                                    Ver detalles
                                                </span>

                                            </a>

                                        </div>

                                    </div>
                                    <!-- BOTON DE AGREGAR AL CARRITO -->
                                    <div class="add-to-cart">

                                        @using (Html.BeginForm(
                                            "Agregar",
                                            "Carrito",
                                            FormMethod.Post))
                                        {
                                            @Html.Hidden(
                                                          "idProducto",
                                                          producto.IdProducto)

                                            <button type="submit"
                                                    class="add-to-cart-btn">
                                                <i class="fa fa-shopping-cart"></i>
                                                Agregar al carrito
                                            </button>
                                        }

                                    </div>

                                </div>

                            </div>

                        }

                    }
                    else
                    {

                        <div class="col-md-12">

                            <div class="alert alert-warning text-center">

                                No se encontraron productos con los filtros seleccionados.

                            </div>

                        </div>

                    }

                </div>
                <div class="store-filter clearfix">

                    <span class="store-qty">

                        Total de productos:
                        <strong>@Model.Count</strong>

                    </span>

                </div>

            </div>

            <!-- /STORE -->
        </div>
        <!-- /row -->
    </div>
    <!-- /container -->
</div>
<!-- /SECTION -->
