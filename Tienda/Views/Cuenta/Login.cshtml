@model Tienda.Models.UsuarioModel

@{
    ViewBag.Title = "Iniciar sesión";
}

<div class="section auth-section">
    <div class="container">
        <div class="row">
            <div class="col-md-5 col-md-offset-3">
                <div class="auth-card">
                    <div class="auth-header text-center">
                        <h2>Iniciar sesión</h2>
                        <p>Ingrese a su cuenta para continuar comprando en Ágata.</p>
                    </div>

                    @if (TempData["MensajeExito"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["MensajeExito"]
                        </div>
                    }

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Cuenta", FormMethod.Post,
                        new { id = "LoginForm", autocomplete = "off" }))
                    {
                        <div class="form-group">
                            <label>Correo electrónico</label>
                            @Html.TextBoxFor(m => m.Correo, new
                            {
                                @class = "input",
                                @type = "email",
                                @placeholder = "ejemplo@correo.com"
                            })
                        </div>

                        <div class="form-group">
                            <label>Contraseña</label>
                            @Html.PasswordFor(m => m.Contrasena, new
                            {
                                @class = "input",
                                @placeholder = "Ingrese su contraseña"
                            })
                        </div>

                        <button type="submit" class="primary-btn auth-btn">
                            Ingresar
                        </button>
                    }

                    <div class="auth-links text-center">
                        <a href="@Url.Action("Recuperar", "Cuenta")">
                            ¿Olvidó su contraseña?
                        </a>
                        <br />
                        <span>¿No tiene cuenta?</span>
                        <a href="@Url.Action("Registro", "Cuenta")">
                            Crear cuenta
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="@Url.Content("~/Scripts/login.js")"></script>
}
