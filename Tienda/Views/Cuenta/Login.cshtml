@{
    ViewBag.Title = "Iniciar Sesión";
}

<div class="section auth-section">
    <div class="container">
        <div class="row">
            <div class="col-md-5 col-md-offset-3">
                <div class="auth-card">
                    <div class="auth-header text-center">
                        <h2>Iniciar Sesión</h2>
                        <p>Ingrese a su cuenta para continuar comprando en Ágata MakeUp.</p>
                    </div>

                    <form>
                        <div class="form-group">
                            <label>Correo electrónico</label>
                            <input class="input" type="email" placeholder="ejemplo@correo.com">
                        </div>

                        <div class="form-group">
                            <label>Contraseña</label>
                            <input class="input" type="password" placeholder="Ingrese su contraseña">
                        </div>

                        <div class="form-group">
                            <div class="input-checkbox">
                                <input type="checkbox" id="recordarme">
                                <label for="recordarme">
                                    <span></span>
                                    Recordarme
                                </label>
                            </div>
                        </div>

                        <button type="button" class="primary-btn auth-btn">Ingresar</button>

                        <div class="auth-links text-center">
                            <a href="@Url.Action("Recuperar", "Cuenta")">¿Olvidó su contraseña?</a>
                            <br>
                            <span>¿No tiene cuenta?</span>
                            <a href="@Url.Action("Registro", "Cuenta")">Crear cuenta</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>