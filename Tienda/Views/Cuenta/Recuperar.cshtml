@model Tienda.Models.UsuarioModel

@{
    ViewBag.Title = "Recuperar acceso";
}

<div class="section auth-section">
    <div class="container">
        <div class="row">
            <div class="col-md-5 col-md-offset-3">
                <div class="auth-card">
                    <div class="auth-header text-center">
                        <h2>Recuperar acceso</h2>
                        <p>Ingrese el correo asociado a su cuenta.</p>
                    </div>

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @if (ViewBag.MensajeExito != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.MensajeExito
                        </div>
                    }

                    @using (Html.BeginForm("Recuperar", "Cuenta", FormMethod.Post,
                        new { id = "RecuperarForm", autocomplete = "off" }))
                    {
                        <div class="form-group">
                            <label>Correo electrónico</label>
                            @Html.TextBoxFor(m => m.Correo, new
                            {
                                @class = "input",
                                @type = "email",
                                @placeholder = "ejemplo@correo.com"
                            })
                        </div>

                        <button type="submit" class="primary-btn auth-btn">
                            Generar contraseña temporal
                        </button>
                    }

                    <div class="auth-links text-center">
                        <a href="@Url.Action("Login", "Cuenta")">
                            Volver al inicio de sesión
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="@Url.Content("~/Scripts/recuperar.js")"></script>
}
